# ═══════════════════════════════════════════════════════════════════════════════
# KALSHI (US-regulated, no VPN needed)
# Get credentials at: kalshi.com > Settings > API Keys
# ═══════════════════════════════════════════════════════════════════════════════

KALSHI_API_KEY_ID=your_kalshi_api_key_id_here

# Path to your RSA private key file (.pem) downloaded from Kalshi
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem


# ═══════════════════════════════════════════════════════════════════════════════
# POLYMARKET (requires VPN for US users)
# Get credentials at: polymarket.com > Account > API Keys
# ═══════════════════════════════════════════════════════════════════════════════

POLY_API_KEY=your_api_key_here
POLY_API_SECRET=your_api_secret_here
POLY_API_PASSPHRASE=your_api_passphrase_here

# Private key of the wallet used to sign orders (never commit this file)
POLY_PRIVATE_KEY=0xyour_private_key_here

# The address that funds the trading wallet
POLY_FUNDER_ADDRESS=0xyour_funder_address_here


# ═══════════════════════════════════════════════════════════════════════════════
# BOT SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════

CAPITAL=1000.0
DRY_RUN=false
